# =============================================================================
# E3 Regulatory Alert SaaS — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- REQUIRED ---

# Anthropic API (for AI summaries)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Session / Auth — MUST change in production!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production

# SEC requires a User-Agent with contact email
USER_AGENT=RegulatoryAlerts/1.0 (your-email@example.com)

# --- DATABASE ---
# Defaults to SQLite (no config needed for local dev)
# For PostgreSQL (production / Railway / Docker):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/regulatory_alerts
# Note: Railway provides DATABASE_URL automatically — just add a Postgres plugin

# --- EMAIL (Postmark recommended for compliance alerts) ---
# Postmark SMTP (recommended — 99%+ inbox rate, <2s delivery):
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=your-postmark-server-api-token
# SMTP_PASSWORD=your-postmark-server-api-token
# SMTP_FROM=alerts@yourdomain.com
# SMTP_USE_TLS=true
#
# AWS SES (cheaper at high volume, more setup):
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=ses-smtp-username
# SMTP_PASSWORD=ses-smtp-password
# SMTP_FROM=alerts@yourdomain.com
# SMTP_USE_TLS=true

# --- STRIPE BILLING ---
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# STRIPE_PRICE_ID_PRO=price_xxxxx
BASE_URL=http://localhost:8000

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# API Authentication — comma-separated API keys (empty = no auth)
# API_KEYS=key1-abc123,key2-def456

# --- AI ---
CLAUDE_MODEL=claude-haiku-4-5-20241022
CLAUDE_MAX_TOKENS=500

# --- BETA MODE ---
BETA_MODE=true
FOUNDING_MEMBER_CAP=50
# BETA_END_DATE=2026-06-01
FOUNDING_MEMBER_DISCOUNT_PCT=40

# --- SCHEDULER ---
FETCH_INTERVAL_MINUTES=30

# --- SYSTEM ALERTING (email admin on scheduler failures) ---
# ALERTING_ENABLED=true
# ALERT_EMAIL=admin@yourdomain.com
# ALERT_COOLDOWN_MINUTES=60

# --- LOGGING ---
LOG_LEVEL=INFO
# LOG_FORMAT=text  # "json" (default, production) or "text" (dev)

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database — defaults to SQLite (no config needed for local dev)
# For PostgreSQL, uncomment (docker-compose.yml sets these automatically):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/regulatory_alerts
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/regulatory_alerts

# SEC requires a User-Agent with contact email
USER_AGENT=RegulatoryAlerts/1.0 (your-email@example.com)

# AI Settings
CLAUDE_MODEL=claude-haiku-4-5-20241022
CLAUDE_MAX_TOKENS=500

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# API Authentication — comma-separated API keys (empty = no auth)
# API_KEYS=key1-abc123,key2-def456

# Email Notifications (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=alerts@yourdomain.com
# SMTP_USE_TLS=true

# Scheduler — auto-fetch interval in minutes (default 30)
# FETCH_INTERVAL_MINUTES=30

# Session / Auth
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=your-random-secret-key-here

# Stripe Billing (required for paid tiers)
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# STRIPE_PRICE_ID_PRO=price_xxxxx
# BASE_URL=https://yourdomain.com

# Logging
LOG_LEVEL=INFO
# LOG_FORMAT=text   # "json" (default) or "text" for dev
